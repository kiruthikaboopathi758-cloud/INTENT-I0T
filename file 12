<!DOCTYPE html>
<html>
<head>

<title>GPS Vehicle Tracking</title>

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="stylesheet"
href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>

body{
    font-family:Arial,sans-serif;
    background:#f5f5f5;
    text-align:center;
}

.container{
    width:90%;
    margin:auto;
}

h1{
    color:#1565c0;
}

#map{
    height:500px;
    border-radius:10px;
}

.info{
    margin:20px;
    font-size:20px;
    font-weight:bold;
}

</style>

</head>

<body>

<div class="container">

<h1>🚗 GPS Vehicle Tracking</h1>

<div class="info">

Latitude :
<span id="lat">--</span>

<br><br>

Longitude :
<span id="lon">--</span>

</div>

<div id="map"></div>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>

const ip = "http://192.168.1.100";

let map = L.map('map').setView([11.1271,78.6569],7);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© OpenStreetMap'
}).addTo(map);

let marker = L.marker([11.1271,78.6569]).addTo(map);

function updateLocation()
{

fetch(ip + "/gps")

.then(response => response.json())

.then(data=>{

document.getElementById("lat").innerHTML=data.latitude;

document.getElementById("lon").innerHTML=data.longitude;

marker.setLatLng([data.latitude,data.longitude]);

map.setView([data.latitude,data.longitude],16);

});

}

updateLocation();

setInterval(updateLocation,5000);

</script>

</body>

</html>