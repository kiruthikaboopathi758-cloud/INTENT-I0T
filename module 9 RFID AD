<!DOCTYPE html>
<html>
<head>
    <title>RFID Attendance Dashboard</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#f5f5f5;
            text-align:center;
        }

        .container{
            width:80%;
            margin:40px auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h1{
            color:#1565c0;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th, td{
            border:1px solid #ccc;
            padding:12px;
            text-align:center;
        }

        th{
            background:#1565c0;
            color:white;
        }

        tr:nth-child(even){
            background:#f2f2f2;
        }
    </style>
</head>

<body>

<div class="container">

<h1>📋 RFID Attendance Dashboard</h1>

<table>

<thead>
<tr>
<th>ID</th>
<th>Name</th>
<th>Date</th>
<th>Time</th>
<th>Status</th>
</tr>
</thead>

<tbody id="attendanceTable">
</tbody>

</table>

</div>

<script>

const ip = "http://192.168.1.100";

function loadAttendance()
{
    fetch(ip + "/attendance")
    .then(response => response.json())
    .then(data => {

        let table = "";

        data.forEach(student => {

            table += `
            <tr>
                <td>${student.id}</td>
                <td>${student.name}</td>
                <td>${student.date}</td>
                <td>${student.time}</td>
                <td>${student.status}</td>
            </tr>
            `;

        });

        document.getElementById("attendanceTable").innerHTML = table;

    });
}

loadAttendance();

setInterval(loadAttendance,3000);

</script>

</body>
</html>
