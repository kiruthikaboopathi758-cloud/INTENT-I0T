<!DOCTYPE html>
<html>
<head>
    <title>Water Tank Monitoring</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#e8f5ff;
            text-align:center;
        }

        .container{
            width:400px;
            margin:60px auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h1{
            color:#0066cc;
        }

        .progress{
            width:100%;
            height:35px;
            background:#ddd;
            border-radius:20px;
            overflow:hidden;
            margin-top:20px;
        }

        .bar{
            height:100%;
            width:0%;
            background:#00bfff;
            color:white;
            text-align:center;
            line-height:35px;
            font-weight:bold;
            transition:width 0.5s;
        }

        .status{
            margin-top:20px;
            font-size:24px;
            color:#333;
        }
    </style>
</head>

<body>

<div class="container">

<h1>💧 Water Tank Monitor</h1>

<div class="progress">
    <div class="bar" id="bar">0%</div>
</div>

<div class="status">
Water Level :
<span id="level">0</span> %
</div>

</div>

<script>

const ip = "http://192.168.1.100";

function updateLevel()
{
    fetch(ip + "/water")
    .then(response => response.json())
    .then(data => {

        let level = data.level;

        document.getElementById("level").innerHTML = level;

        document.getElementById("bar").style.width = level + "%";

        document.getElementById("bar").innerHTML = level + "%";

    });
}

updateLevel();

setInterval(updateLevel,2000);

</script>

</body>
</html>